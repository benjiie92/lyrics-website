# Copy this file to .env and fill values before running locally
# Do NOT commit your real .env

# Server
PORT=3000
CLIENT_URL=http://localhost:3000

# Admin
ADMIN_PASSWORD=your_admin_password_here

# MySQL
MYSQLHOST=localhost
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=lyrics_app
MYSQLPORT=3306

# For production (Railway will provide these values when you provision a plugin)
# Leave blank locally and set real values on the host
